# Local LLM Environment Configuration

# Model Configuration
# Place the GGUF model paths here. Recommended starter: Llama-3-8B-Instruct
MODEL_PATH=./models/Meta-Llama-3-8B-Instruct.Q4_K_M.gguf

# To host MULTIPLE models simultaneously, update the config.json file!
# How to add more: Open config.json, copy one of the objects inside the "models": [] array,
# paste it below, update the "model" path to your new .gguf, and give it a unique "model_alias".
# e.g., MULTI_MODEL_CONFIG=./config.json
MULTI_MODEL_CONFIG=./config.json

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Hardware Acceleration & Tuning Variables
# Context length (Max tokens model can consider at once)
N_CTX=8192

# Threads for CPU (Adjust based on your CPU cores, e.g., 8)
N_THREADS=4

# GPU Layers to offload (Set to 0 for CPU only, or -1 to offload all to GPU if available)
N_GPU_LAYERS=-1

# ─── RAG Server Configuration ───────────────────────────────────────────────
# Base URL of the running llama_cpp.server OpenAI-compatible API
LLM_BASE_URL=http://127.0.0.1:8000/v1
# Model alias to use for RAG chat (must match model_alias in config.json)
LLM_MODEL=llama-3-8b
# Host and port for the RAG API + Web UI
RAG_HOST=0.0.0.0
RAG_PORT=8001
# Local LanceDB persistence directory (vector store)
LANCE_DIR=./rag_storage/lancedb
# FastEmbed offline embedding model (ONNX-based, no torch required)
EMBED_MODEL=BAAI/bge-small-en-v1.5
